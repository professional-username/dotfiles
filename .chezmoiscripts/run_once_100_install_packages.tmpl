#!/bin/bash
# vim:filetype=bash:foldmethod=marker:fmr=<<<,>>>

{{ if eq .chezmoi.osRelease.id "void" }}

# ━━━━━━━━━━━━━━━━━━━━━━━━━ VOID PACKAGES ━━━━━━━━━━━━━━━━━━━━━━━━━

# Desktop Environment packages <<<
sudo xbps-install -y \
    xorg \
    picom \
    bspwm \
    sxhkd \
    rofi \
    kitty \
    fish-shell \
    feh \
	dunst
# >>>

# Useful programs <<<
sudo xbps-install -y \
    curl \
    git \
    neovim \
    firefox \
    Thunar
sh -c 'curl -fLo "${XDG_DATA_HOME:-$HOME/.local/share}"/nvim/site/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
# >>>

# Fonts and themes <<<
sudo xbps-install -y \
    nerd-fonts \
    gtk-engine-murrine \
    gnome-themes-extra
# >>>

# Eye candy <<<
sudo xbps-install -y \
	neofetch
#>>>


{{ else if eq .chezmoi.osRelease.id "arch" }} # TODO: Or Artix

# ━━━━━━━━━━━━━━━━━━━━━━━━━ ARCH PACKAGES ━━━━━━━━━━━━━━━━━━━━━━━━━

# Desktop Environment packages <<<
yay -S --noconfirm --needed \
    xorg \
    xorg-xinit \
    picom \
    bspwm \
    sxhkd \
    rofi \
    kitty \
    fish \
    feh \
	dunst
# >>>

# Useful programs <<<
yay -S --noconfirm --needed \
    curl \
    git \
    neovim \
    firefox \
    thunar \
    neovim-plug
# >>>

# Fonts and themes <<<
yay -S --noconfirm --needed \
    nerd-fonts-fira-code
# >>>

# Eye candy <<<
yay -S --noconfirm --needed \
	neofetch
#>>>

{{ end }}
